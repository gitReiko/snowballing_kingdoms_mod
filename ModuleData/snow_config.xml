<?xml version="1.0" encoding="utf-8" ?>
<SnowConfigs>

	<!-- 

	Only the first SnowConfig will work. Do not create other exemplars to avoid confusion.

	===

	1. clan_creation_factor 

	Determines how many settlements each clan should have. Once the limit is exceeded, a new clan will be created for the kingdom.

	Should be a number. Use a dot to specify the decimal separator.

	example: clan_creation_factor="1.7"

	===

	2. create_every_days
	
	New clans will be created after a specified number of days.

	The value is an integer (1 to 65535).

	example: create_every_days="10"

	===
	
	-->

	<SnowConfig id="config"
			  clan_creation_factor="1.7"
			  create_every_days="10"

	/>

</SnowConfigs>